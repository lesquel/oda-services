# ── Services: Environment Variables ──────────────────────────────────────────
# Shared by gateway, write-api, read-api via docker-compose or manual export.

# ── Secrets ──────────────────────────────────────────────────────────────────
INTERNAL_SECRET=change-internal-secret-in-production
JWT_SECRET=change-jwt-secret-in-production

# ── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/oda?sslmode=disable

# ── PostgreSQL read replica (used by read-api in dev mode) ───────────────────
DATABASE_URL_READ=postgres://postgres:postgres@localhost:5433/oda?sslmode=disable

# ── Admin seed ───────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@oda.com
ADMIN_PASSWORD=OdaAdmin2025Change!

# ── Service Ports ────────────────────────────────────────────────────────────
GATEWAY_PORT=8080
WRITE_API_PORT=8082
READ_API_PORT=8083

# ── Internal URLs (used by gateway to proxy) ─────────────────────────────────
WRITE_API_URL=http://localhost:8082
READ_API_URL=http://localhost:8083

# ── NATS (message broker) ────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ── Moderation (Python service) ──────────────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
MODERATION_THRESHOLD=0.7
MODERATION_API_PORT=8084
